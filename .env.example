# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard:
#   Project Settings -> Environment Variables

# Gemini API key (only required if/when Gemini features are enabled)
GEMINI_API_KEY=""

# Public site URL. On Vercel, you can leave this unset and use
# process.env.VERCEL_URL (auto-injected) instead.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
